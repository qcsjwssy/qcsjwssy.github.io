---
const { title = '我的博客', description = '一个记录技术与成长的地方' } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #f5f7fb;
        --card: #ffffff;
        --text: #1f2328;
        --sub: #667085;
        --link: #1d4ed8;
        --border: #e5e7eb;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        --tag-bg: #eef4ff;
        --tag-text: #3159b7;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
          "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        background: linear-gradient(180deg, #f8fafc 0%, #f5f7fb 100%);
        color: var(--text);
        line-height: 1.75;
      }

      a {
        color: var(--link);
        text-decoration: none;
      }

      a:hover {
        text-decoration: none;
      }

      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 32px 20px 72px;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        margin-bottom: 32px;
        padding: 16px 0 22px;
        border-bottom: 1px solid var(--border);
      }

      .site-title {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 24px;
        font-weight: 800;
        color: var(--text);
      }

      .site-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--link);
        display: inline-block;
      }

      nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
      }

      nav a {
        color: var(--sub);
        font-weight: 600;
      }

      nav a:hover {
        color: var(--text);
      }

      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 28px;
        margin-bottom: 22px;
        box-shadow: var(--shadow);
      }

      h1, h2, h3 {
        line-height: 1.3;
        margin-top: 0;
      }

      h1 {
        font-size: 44px;
        margin-bottom: 16px;
      }

      h2 {
        font-size: 28px;
        margin-bottom: 18px;
      }

      .muted {
        color: var(--sub);
      }

      .hero {
        padding: 40px 32px;
      }

      .hero p {
        font-size: 18px;
        margin: 0;
      }

      .article-list {
        display: grid;
        gap: 18px;
      }

      .post-card {
        display: block;
        background: #fff;
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 22px 22px 18px;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .post-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
        border-color: #c7d2fe;
      }

      .post-title {
        margin: 0 0 8px;
        color: var(--text);
        font-size: 24px;
      }

      .post-desc {
        margin: 0 0 14px;
        color: var(--sub);
      }

      .post-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 12px;
        align-items: center;
        color: var(--sub);
        font-size: 14px;
      }

      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        background: var(--tag-bg);
        color: var(--tag-text);
        font-size: 13px;
        line-height: 1;
        font-weight: 600;
      }

      article.card h1 {
        font-size: 38px;
        margin-bottom: 10px;
      }

      article.card p,
      article.card li {
        font-size: 17px;
      }

      article.card ul,
      article.card ol {
        padding-left: 24px;
      }

      article.card pre {
        overflow-x: auto;
        padding: 16px;
        border-radius: 14px;
        background: #0f172a;
        color: #e5e7eb;
      }

      article.card code {
        font-family: Consolas, Monaco, monospace;
      }

      footer {
        margin-top: 56px;
        color: var(--sub);
        font-size: 14px;
      }

      @media (max-width: 720px) {
        .container {
          padding: 22px 14px 52px;
        }

        header {
          align-items: flex-start;
          flex-direction: column;
        }

        .hero {
          padding: 28px 20px;
        }

        h1 {
          font-size: 34px;
        }

        .post-title {
          font-size: 22px;
        }

        article.card h1 {
          font-size: 30px;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <a href="/" class="site-title">
          <span class="site-dot"></span>
          <span>鹏翔的博客</span>
        </a>

        <nav>
          <a href="/">首页</a>
          <a href="/about">关于</a>
          <a href="https://github.com/qcsjwssy" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
        © 2026 鹏翔 · 用 Astro 构建
      </footer>
    </div>
  </body>
</html>