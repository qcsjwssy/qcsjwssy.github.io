---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="首页 | 鹏翔的博客" description="后端开发、AI Agent、项目复盘和学习笔记">
  <section class="card hero">
    <h1>你好，我是鹏翔</h1>
    <p class="muted">
      这里记录 Java 后端、AI Agent、项目复盘、学习笔记，以及我在技术成长过程中的思考与沉淀。
    </p>
  </section>

  <section class="card">
    <h2>最新文章</h2>

    {posts.length === 0 ? (
      <p class="muted">还没有文章，先写下第一篇技术总结吧。</p>
    ) : (
      <div class="article-list">
        {posts.map((post) => (
          <a class="post-card" href={`/posts/${post.id}`}>
            <h3 class="post-title">{post.data.title}</h3>
            <p class="post-desc">{post.data.description}</p>

            <div class="post-meta">
              <span>发布时间：{post.data.pubDate.toLocaleDateString('zh-CN')}</span>

              {post.data.tags.length > 0 && (
                <div class="tags">
                  {post.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>